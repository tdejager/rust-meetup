<!-- UTM capture + link persistence -->
<script>
  (function () {
    var UTM_KEYS = ['utm_id', 'utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content'];
    var STORAGE_KEY = 'utm_params';
    var INTERNAL_HOSTS = ['modular.com', 'www.modular.com', 'console.modular.com', 'modular-rebuild.webflow.io'];

    function captureFromUrl() {
      var params = new URLSearchParams(window.location.search);
      var found = {};
      var hasUtm = false;
      UTM_KEYS.forEach(function (key) {
        var val = params.get(key);
        found[key] = val;
        if (val) hasUtm = true;
      });
      if (hasUtm) {
        try {
          sessionStorage.setItem(STORAGE_KEY, JSON.stringify(found));
        } catch (e) {}
      }
    }

    function getStored() {
      try {
        return JSON.parse(sessionStorage.getItem(STORAGE_KEY) || '{}');
      } catch (e) {
        return {};
      }
    }

    function isInternal(url) {
      return INTERNAL_HOSTS.indexOf(url.hostname) !== -1;
    }

    function rewriteAnchor(a) {
      var href = a.getAttribute('href');
      if (!href || href.charAt(0) === '#' || /^(mailto|tel|javascript):/i.test(href)) return;
      var stored = getStored();
      if (
        !Object.values(stored).some(function (v) {
          return v;
        })
      )
        return;
      var url;
      try {
        url = new URL(href, window.location.href);
      } catch (e) {
        return;
      }
      if (!isInternal(url)) return;
      var changed = false;
      UTM_KEYS.forEach(function (key) {
        if (stored[key]) {
          url.searchParams.set(key, stored[key]);
          changed = true;
        }
      });
      if (changed) a.href = url.toString();
    }

    function rewriteAll() {
      document.querySelectorAll('a[href]').forEach(rewriteAnchor);
    }

    function observe() {
      new MutationObserver(function (mutations) {
        mutations.forEach(function (m) {
          m.addedNodes.forEach(function (node) {
            if (node.nodeType !== 1) return;
            if (node.tagName === 'A') rewriteAnchor(node);
            else if (node.querySelectorAll) node.querySelectorAll('a[href]').forEach(rewriteAnchor);
          });
        });
      }).observe(document.body || document.documentElement, { childList: true, subtree: true });
    }

    captureFromUrl();
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function () {
        rewriteAll();
        observe();
      });
    } else {
      rewriteAll();
      observe();
    }
  })();
</script>

<!-- Cloudflare -->
<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<!-- Playground iFrame -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const iframe = document.getElementById('playground-iframe');
    const loader = document.getElementById('playground-loader');
    if (!iframe || !loader) return;

    // Loader reveal
    let revealed = false;
    const reveal = () => {
      if (revealed) return;
      revealed = true;
      iframe.style.visibility = 'visible';
      loader.style.display = 'none';
    };
    iframe.addEventListener('load', reveal);
    setTimeout(reveal, 9000); // fallback

    // Scroll lock
    let userHasInteracted = false;
    const lockScroll = () => {
      if (!userHasInteracted) return;
      const scrollY = window.scrollY;
      const lock = () => window.scrollTo({ top: scrollY, behavior: 'instant' });
      window.addEventListener('scroll', lock);
      const interval = setInterval(() => window.scrollTo({ top: scrollY, behavior: 'instant' }), 10);
      setTimeout(() => {
        window.removeEventListener('scroll', lock);
        clearInterval(interval);
      }, 500);
    };

    // Mark interaction and attach listeners
    iframe.addEventListener('mousedown', () => {
      userHasInteracted = true;
      lockScroll();
    });
    window.addEventListener('keydown', (e) => {
      userHasInteracted = true;
      if (e.key === 'Enter') lockScroll();
    });

    // Same-origin iframe keydown fallback
    iframe.addEventListener('load', () => {
      try {
        iframe.contentWindow?.addEventListener('keydown', (e) => {
          userHasInteracted = true;
          if (e.key === 'Enter') lockScroll();
        });
      } catch (e) {
        /* cross-origin, skip */
      }
    });
  });
</script>

<style>
  .pg-loader {
    position: absolute;
    inset: 0;
    z-index: 10;
    display: grid;
    place-content: center;
    justify-items: center;
    gap: 14px;
    background: #fff;
    color: #676d71;
    font:
      500 14px/1 Inter,
      system-ui,
      -apple-system,
      Segoe UI,
      Roboto,
      sans-serif;
  }

  .pg-spinner {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    border: 3px solid #b5c0f6;
    border-top-color: #637bff;
    animation: pg-spin 0.9s linear infinite;
  }

  #playground-iframe {
    box-shadow: 0 20px 20px 0 rgba(5, 13, 29, 0.2);
    border: 1px solid #d4dae4;
    border-radius: 4px;
  }

  @keyframes pg-spin {
    to {
      transform: rotate(360deg);
    }
  }
</style></body></html>